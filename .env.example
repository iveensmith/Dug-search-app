# Copy to .env for local dev, or use as the checklist of env vars to set in
# your hosting provider's dashboard (e.g. Vercel) for production.

# --- Database ---
# Local dev: your local Postgres connection string.
# Production (Supabase): use the POOLED "Transaction" connection string
# (port 6543) here — the app runs many short-lived serverless connections.
DATABASE_URL="postgresql://postgres@localhost:5432/drugfinder"

# Production only: Supabase's DIRECT (non-pooled, port 5432) connection
# string. Used only for running migrations, which need prepared-statement
# support that pooled/pgbouncer connections don't provide. Leave unset
# locally — prisma.config.ts falls back to DATABASE_URL.
# DIRECT_URL="postgresql://postgres:[password]@[project].supabase.co:5432/postgres"

# --- Auth ---
# Generate a real random value for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev-only-secret-change-in-production"

# --- File storage (prescription photo uploads) ---
# Local dev: uses disk storage at this path, no other vars needed.
UPLOADS_DIR="./storage/uploads"

# Production: set these three to switch to Supabase Storage (S3-compatible)
# instead of local disk, which doesn't persist on serverless hosts. Create a
# PRIVATE bucket named e.g. "prescriptions" in the Supabase dashboard first —
# access control is enforced entirely by our API route, not by Storage.
# SUPABASE_URL="https://[project].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="[service role key, NOT the anon/public key]"
# SUPABASE_STORAGE_BUCKET="prescriptions"
